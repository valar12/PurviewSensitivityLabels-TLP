<# ==========================================
  Updated 2026-05-24
  Release: v1.2.0
  TLP-aligned sensitivity labels (Purview)
========================================== #>

param(
  [Parameter(Mandatory = $true)]
  [ValidatePattern('^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$')]
  [string]$TenantPrimaryDomain,

  [Parameter(Mandatory = $false)]
  [ValidateSet("Retail","USGovGCCHigh","USGovDoD")]
  [string]$CloudEnvironment = "Retail",

  [Parameter(Mandatory = $false)]
  [string]$ConfigurationPath = "$PSScriptRoot/TlpLabelConfig.json",

  [Parameter(Mandatory = $false)]
  [switch]$DryRun,

  [Parameter(Mandatory = $false)]
  [switch]$FailOnDrift
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

Import-Module ExchangeOnlineManagement -ErrorAction Stop
. "$PSScriptRoot/TlpLabelModule.ps1"

$config = Get-TlpConfiguration -Path $ConfigurationPath
Connect-TlpPurviewSession -CloudEnvironment $CloudEnvironment
Test-TlpPrerequisites

$rightsDefinition = $config.Defaults.RightsDefinition
$executionReport = [ordered]@{
  TimestampUtc = (Get-Date).ToUniversalTime().ToString("o")
  CloudEnvironment = $CloudEnvironment
  ConfigVersion = $config.ConfigVersion
  LabelsChanged = @()
  LabelsUnchanged = @()
  LabelsFailed = @()
}
$driftFound = $false

foreach ($label in $config.Labels) {
  $currentLabel = Get-Label -Identity $label.Name -ErrorAction SilentlyContinue
  $existingPriority = if ($null -ne $currentLabel) { [int]$currentLabel.Priority } else { -1 }
  $needsCreateOrUpdate = ($null -eq $currentLabel) -or ($existingPriority -ne [int]$label.Priority
    -or [string]$currentLabel.Tooltip -ne [string]$label.Tooltip
    -or [string]$currentLabel.Comment -ne [string]$label.Comment)
  if ($needsCreateOrUpdate) {
    $driftFound = $true
  }

  if ($DryRun) {
    if ($needsCreateOrUpdate) { $executionReport.LabelsChanged += $label.Name } else { $executionReport.LabelsUnchanged += $label.Name }
    continue
  }

  $labelParams = @{
    Name = $label.Name
    Priority = [int]$label.Priority
    Tooltip = $label.Tooltip
    Comment = $label.Comment
    ColorHex = $label.ColorHex
  }
  try {
    New-OrUpdateTlpLabel @labelParams
    if ($needsCreateOrUpdate) { $executionReport.LabelsChanged += $label.Name } else { $executionReport.LabelsUnchanged += $label.Name }
  } catch {
    $executionReport.LabelsFailed += "$($label.Name): $($_.Exception.Message)"
    continue
  }

  if ($label.Encryption) {
    $principal = switch ($label.Encryption.PrincipalType) {
      "AuthenticatedUsers" { "AuthenticatedUsers:$rightsDefinition" }
      "TenantDomain" { "${TenantPrimaryDomain}:$rightsDefinition" }
      "Literal" { $label.Encryption.RightsDefinitions }
      default { throw "Unsupported PrincipalType '$($label.Encryption.PrincipalType)' for label '$($label.Name)'." }
    }

    $encryptionParams = @{
      EncryptionEnabled = [bool]$label.Encryption.Enabled
      EncryptionProtectionType = "Template"
      EncryptionContentExpiredOnDateInDaysOrNever = "Never"
      EncryptionOfflineAccessDays = [int]$config.Defaults.OfflineDays
      EncryptionRightsDefinitions = $principal
      ApplyContentMarkingHeaderEnabled = [bool]$label.Markings.HeaderEnabled
      ApplyContentMarkingHeaderText = $label.Markings.HeaderText
      ApplyContentMarkingHeaderFontName = $config.Defaults.FontName
      ApplyContentMarkingHeaderFontSize = [int]$config.Defaults.HeaderFontSize
      ApplyContentMarkingHeaderAlignment = $config.Defaults.HeaderAlign
    }
    Invoke-LabelSet -LabelName $label.Name -Parameters $encryptionParams
  }

  if ($label.Container.Enabled) {
    $containerParams = @{
      ContentType = "File,Email,Site,UnifiedGroup"
      SiteAndGroupProtectionEnabled = $true
      SiteAndGroupProtectionPrivacy = $label.Container.Privacy
      SiteAndGroupProtectionAllowAccessToGuestUsers = [bool]$label.Container.AllowGuestUsers
      SiteExternalSharingControlType = $label.Container.ExternalSharing
    }
    Invoke-LabelSet -LabelName $label.Name -Parameters $containerParams
  }

  if ($label.Validation) {
    $expected = @{}
    foreach ($entry in $label.Validation.PSObject.Properties) { $expected[$entry.Name] = $entry.Value }
    Assert-LabelConfiguration -LabelName $label.Name -Expected $expected
    Assert-LabelConfiguration -LabelName $label.Name -Expected @{
      Priority = [string]$label.Priority
      Tooltip = [string]$label.Tooltip
      Comment = [string]$label.Comment
    }
    if ($label.Container -and $label.Container.Enabled) {
      Assert-LabelConfiguration -LabelName $label.Name -Expected @{
        SiteAndGroupProtectionEnabled = "True"
        SiteAndGroupProtectionPrivacy = [string]$label.Container.Privacy
        SiteExternalSharingControlType = [string]$label.Container.ExternalSharing
      }
    }
  }
}

$reportPath = Join-Path $PSScriptRoot "TlpLabelExecutionReport.json"
$executionReport | ConvertTo-Json -Depth 10 | Out-File -FilePath $reportPath -Encoding utf8
Write-Host "Execution report written to $reportPath"

if ($DryRun) {
  Write-Host "Dry-run complete. No changes were applied."
  if ($FailOnDrift -and $driftFound) {
    throw "Drift detected in dry-run mode and -FailOnDrift was specified."
  }
}

Write-Host "Done. Labels created/updated, validated, and configured from JSON."
Disconnect-ExchangeOnline -Confirm:$false
Write-Host "Disconnected from IPPSSession."
